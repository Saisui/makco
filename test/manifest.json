{
  "manifest_version": 3,
  "name": "媒体资源下载器",
  "version": "1.0",
  "description": "下载当前页面中的图片、视频、音频等媒体资源",
  "permissions": ["downloads", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}